{
	"compilerOptions": {
		
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "bundler",
		"allowJs": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"lib": ["DOM", "ES2020"]
	},
	"include": ["src/**/*.ts"]
}
