# Copy this file to `.env` and set the absolute path to your Obsidian vault.
#
# `npm run build` and `npm run dev` then copy main.js, manifest.json and
# styles.css into <vault>/.obsidian/plugins/good-bases/ so you can test the
# plugin live (reload it in Obsidian after a build — Obsidian has no hot reload).
#
# Leave unset, or delete .env, to skip the copy entirely (e.g. in CI/release).
# A leading ~/ is expanded to your home directory.
OBSIDIAN_VAULT_PATH="/absolute/path/to/Your Vault"
